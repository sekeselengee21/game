.backend-git-backup/

# Docker Compose environment files may contain production secrets.
.env
.env.*
!.env.example

# Local backend secrets and machine-specific config.
backend/config/application.properties
backend/config/application.properties.backup_*
backend/config/*.pem
backend/config/config.pgerd
backend/config/botusers.txt
backend/config/test.csv

# Local package-manager cache generated by Dockerized frontend installs.
p-frontend/.pnpm-store/
p-frontend/node_modules/
p-frontend/dist/
