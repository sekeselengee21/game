DB_USER=poker_prod_user
DB_PASSWORD=change_me
DB_NAME=poker_db

BACKEND_PORT=8080
FRONTEND_PORT=80

# Public URL used by the browser for REST and WebSocket traffic.
VITE_BACKEND_URL=https://your-domain.example

# Optional: email of the account to auto-promote to ADMIN on startup and at
# registration. Leave blank to disable. Register this email, then it becomes
# admin automatically (no manual SQL). Remember to log out/in to refresh the JWT.
BOOTSTRAP_ADMIN_EMAIL=
